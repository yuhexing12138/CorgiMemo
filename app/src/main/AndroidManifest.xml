<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    
    <!-- 前台服务权限（用于语音播放） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    
    <!-- 位置权限 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- 震动权限（触觉反馈） -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- 通知权限（Android 13+ 需要） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- 精确闹钟权限（Android 12+ 需要） -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    
    <uses-feature android:name="android.hardware.location.gps" />

    <application
        android:name=".CorgiMemoApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:label="@string/app_name"
        android:icon="@drawable/ic_launcher"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.CorgiMemo"
        tools:targetApi="34">
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 语音播放前台服务 -->
        <service
            android:name=".service.VoicePlaybackService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- 通知操作按钮广播接收器 -->
        <receiver
            android:name=".receiver.ReminderActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.corgimemo.app.ACTION_REMINDER" />
                <action android:name="com.corgimemo.app.ACTION_COMPLETE" />
                <action android:name="com.corgimemo.app.ACTION_SNOOZE_10M" />
                <action android:name="com.corgimemo.app.ACTION_SNOOZE_1H" />
                <action android:name="com.corgimemo.app.ACTION_SNOOZE_TOMORROW" />
                <action android:name="com.corgimemo.app.ACTION_SNOOZE_WEEKEND" />
            </intent-filter>
        </receiver>

        <!-- 1x1 快速添加小部件 -->
        <receiver
            android:name=".widget.QuickAddWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/quick_add_widget_info" />
        </receiver>

        <!-- 2x2 今日待办预览小部件 -->
        <receiver
            android:name=".widget.TodayPreviewWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/today_preview_widget_info" />
        </receiver>

        <!-- 4x2 完整待办列表小部件 -->
        <receiver
            android:name=".widget.TodoListWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/todo_list_widget_info" />
        </receiver>

        <!-- 小部件刷新广播接收器 -->
        <receiver
            android:name=".widget.WidgetUpdateReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.corgimemo.app.ACTION_REFRESH_WIDGET" />
            </intent-filter>
        </receiver>

        <!-- 小部件操作广播接收器 -->
        <receiver
            android:name=".widget.WidgetActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.corgimemo.app.ACTION_COMPLETE_TODO" />
            </intent-filter>
        </receiver>

        <!-- 自动备份广播接收器 -->
        <receiver
            android:name=".receiver.AutoBackupReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.corgimemo.app.ACTION_AUTO_BACKUP" />
            </intent-filter>
        </receiver>

        <!-- FileProvider 用于分享文件 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
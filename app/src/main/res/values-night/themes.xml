<!-- 深色模式主题配置 -->

<resources>
    <!-- 深色模式应用主主题 -->
    <style name="Theme.CorgiMemo" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- 主色调（保持不变） -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorPrimaryLight">@color/colorPrimaryLight</item>
        
        <!-- 辅助色 -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryVariant</item>
        
        <!-- 深色背景色 -->
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        
        <!-- 文字颜色（适配深色背景） -->
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="colorOnBackground">@color/colorOnBackground</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        
        <!-- 错误颜色 -->
        <item name="colorError">@color/colorError</item>
        <item name="colorOnError">@color/colorOnError</item>
        
        <!-- 状态栏和导航栏（深色模式） -->
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
        
        <!-- 动作栏样式 -->
        <item name="actionBarStyle">@style/ActionBar</item>
    </style>
    
    <!-- 动作栏样式（深色模式） -->
    <style name="ActionBar" parent="@style/Widget.Material3.ActionBar">
        <item name="titleTextColor">@color/colorOnPrimary</item>
        <item name="subtitleTextColor">@color/colorOnPrimary</item>
    </style>
    
    <!-- 卡片样式 -->
    <style name="Widget.CorgiMemo.Card" parent="Widget.Material3.Card">
        <item name="shapeAppearance">@style/ShapeAppearance.CorgiMemo.Medium</item>
    </style>
    
    <!-- 按钮样式 -->
    <style name="Widget.CorgiMemo.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.CorgiMemo.Medium</item>
    </style>
    
    <!-- 形状外观配置 -->
    <style name="ShapeAppearance.CorgiMemo.Medium" parent="ShapeAppearance.Material3.Medium">
        <item name="cornerSize">16dp</item>
    </style>
</resources>